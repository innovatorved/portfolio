---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogPosts from "@/components/BlogPosts.astro";

// ISR-like behavior: Cache for 60s, stale-while-revalidate for 1 hour
Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=0, s-maxage=600, stale-while-revalidate=3600",
);
---

<BaseLayout
    title="Blog"
    description="Read my blog by Ved Gupta (innovatorved | vedgupta) on Cloud, Full Stack, and AI."
>
    <section>
        <h1 class="font-semibold text-2xl mb-8 tracking-tighter">My Blog</h1>
        <BlogPosts />
    </section>
</BaseLayout>
