---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page Not Found">
    <section class="flex flex-col items-center justify-center min-h-[50vh]">
        <h1 class="text-4xl font-bold mb-4">404</h1>
        <p class="text-neutral-600 dark:text-neutral-400 mb-8">
            The page you're looking for doesn't exist.
        </p>
        <a
            href="/"
            class="px-4 py-2 bg-neutral-900 dark:bg-neutral-100 text-white dark:text-black rounded-md transition-all hover:opacity-80"
        >
            Go Home
        </a>
    </section>
</BaseLayout>
