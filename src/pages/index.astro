---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Experience from "@/components/Experience.astro";
import Education from "@/components/Education.astro";
import BlogPosts from "@/components/BlogPosts.astro";
import ProjectPosts from "@/components/ProjectPosts.astro";
---

<BaseLayout title="Ved Prakash Gupta">
	<section>
		<h1 class="mb-8 text-2xl font-semibold tracking-tighter">
			Ved Prakash Gupta
		</h1>
		<p class="mb-4">
			Cloud Engineer | Full Stack & Generative AI | Azure & Google Cloud
			Certified
		</p>
		<div
			class="mb-4 rounded-sm border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-700 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300"
		>
			<p class="m-0">        Open to Cloud Engineering, DevOps, Full Stack, and Generative AI roles — let's talk.
</p>
		</div>
		<p class="mb-4 text-sm">
			I started as a freelancer, writing applications with React, Next.js,
			JavaScript, and TypeScript, then grew into DevOps practices - 
			containerizing with Docker and orchestrating with Kubernetes to ship
			applications reliably at scale.
			<br /><br />
			Currently at LTIMindtree, I design and implement scalable Azure cloud infrastructure and write the application code that runs on it - AI-powered apps and agents using Azure OpenAI, not just the infrastructure around them. 
			<br />
			See Projects for what I've built, or reach out at me@vedgupta.in.
		</p>
		<Experience />
		<Education />
		<div class="my-8">
			<h2 class="mb-8 text-xl font-semibold tracking-tighter">
				Featured Projects
			</h2>
			<ProjectPosts limit={3} />
			<a
				href="/projects"
				class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
			>
				View all projects →
			</a>
		</div>
		<div class="my-8">
			<h2 class="mb-8 text-xl font-semibold tracking-tighter">
				Featured Posts
			</h2>
			<BlogPosts />
		</div>
	</section>
</BaseLayout>
