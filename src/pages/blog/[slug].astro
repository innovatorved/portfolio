---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/utils";
import { getAllPosts } from "@/lib/db";
import { resolvePostImages } from "@/lib/images";
import { marked } from "marked";

export async function getStaticPaths() {
    const rawPosts = await getAllPosts("blog");
    const posts = await resolvePostImages(rawPosts, "blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const contentHtml = await marked.parse(post.content || "");
const ogImage = post.image || `/og?title=${encodeURIComponent(post.title)}`;
---

<BaseLayout
    title={post.title}
    description={post.summary || undefined}
    image={ogImage || undefined}
>
    <section>
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "BlogPosting",
                headline: post.title,
                datePublished: post.publishedAt
                    ? post.publishedAt.toISOString()
                    : new Date().toISOString(),
                dateModified: post.publishedAt
                    ? post.publishedAt.toISOString()
                    : new Date().toISOString(),
                description: post.summary,
                image: post.image || ogImage,
                url: `${Astro.site}blog/${post.slug}`,
                author: {
                    "@type": "Person",
                    name: "Ved Gupta Portfolio",
                },
            })}
        />
        <h1 class="title font-semibold text-2xl tracking-tighter">
            {post.title}
        </h1>
        <div class="flex justify-between items-center mt-2 mb-8 text-sm">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
                {formatDate(post.publishedAt)}
            </p>
        </div>
        <article class="prose" set:html={contentHtml} />
    </section>
</BaseLayout>
