---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/utils";
import { getPostBySlug } from "@/lib/db";
import { marked } from "marked";

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect("/404");
}

const post = await getPostBySlug(slug, "blog");

if (!post) {
    return Astro.redirect("/404");
}

const contentHtml = await marked.parse(post.content || "");

// Vercel Edge Caching (ISR-like behavior)
// Cache for 60 seconds (s-maxage), stale-while-revalidate for 1 hour
Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=0, s-maxage=600, stale-while-revalidate=3600",
);

const ogImage = post.image || `/og?title=${encodeURIComponent(post.title)}`;
---

<BaseLayout
    title={post.title}
    description={post.summary || undefined}
    image={ogImage || undefined}
>
    <section>
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "BlogPosting",
                headline: post.title,
                datePublished: post.publishedAt
                    ? post.publishedAt.toISOString()
                    : new Date().toISOString(),
                dateModified: post.publishedAt
                    ? post.publishedAt.toISOString()
                    : new Date().toISOString(),
                description: post.summary,
                image: post.image || ogImage,
                url: `${Astro.site}blog/${post.slug}`,
                author: {
                    "@type": "Person",
                    name: "Ved Gupta Portfolio",
                },
            })}
        />
        <h1 class="title font-semibold text-2xl tracking-tighter">
            {post.title}
        </h1>
        <div class="flex justify-between items-center mt-2 mb-8 text-sm">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
                {formatDate(post.publishedAt)}
            </p>
        </div>
        <article class="prose" set:html={contentHtml} />
    </section>
</BaseLayout>
